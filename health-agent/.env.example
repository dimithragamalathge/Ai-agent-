# ─── Brand ────────────────────────────────────────────────────────────────────
INSTAGRAM_HANDLE=@YourHandle
BRAND_NAME=YourBrandName

# ─── Claude API ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Canva Connect API ────────────────────────────────────────────────────────
# Get from: https://www.canva.com/developers/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# IDs of your Canva templates (run: python main.py list-templates to find them)
CANVA_SINGLE_POST_TEMPLATE_ID=
CANVA_CAROUSEL_TEMPLATE_ID=
# Populated automatically after running: python main.py canva-auth
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# ─── Instagram Graph API ──────────────────────────────────────────────────────
# Setup guide in README.md — requires Facebook App + Meta App Review
INSTAGRAM_USER_ID=
# Long-lived token (valid 60 days). Refresh with: python main.py refresh-token
INSTAGRAM_ACCESS_TOKEN=

# ─── PubMed API ───────────────────────────────────────────────────────────────
# Free key at: https://www.ncbi.nlm.nih.gov/account/
# Increases rate limit from 3/s to 10/s. Leave blank to use without a key.
PUBMED_API_KEY=

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_DAYS=mon,wed,fri
SCHEDULE_TIME=08:00

# ─── App ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite:///health_agent.db
OUTPUT_DIR=./output/images
