# ─── Brand ────────────────────────────────────────────────────────────────────
INSTAGRAM_HANDLE=@YourHandle
BRAND_NAME=YourBrandName

# ─── Claude API ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Canva Connect API ────────────────────────────────────────────────────────
# Get from: https://www.canva.com/developers/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# Set this to your PythonAnywhere URL + /canva/callback
# e.g. https://yourusername.pythonanywhere.com/canva/callback
CANVA_REDIRECT_URI=https://yourusername.pythonanywhere.com/canva/callback
# IDs of your Canva templates — find them via the dashboard after connecting
CANVA_SINGLE_POST_TEMPLATE_ID=
CANVA_CAROUSEL_TEMPLATE_ID=
# These are filled in automatically when you click "Connect Canva" in the dashboard
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=

# ─── Instagram Graph API ──────────────────────────────────────────────────────
# Full setup guide in SETUP_GUIDE.md — requires Facebook App
INSTAGRAM_USER_ID=
# Long-lived token (valid 60 days). Refresh via PythonAnywhere console:
#   python run_pipeline.py --refresh-token  (coming in Phase 2)
INSTAGRAM_ACCESS_TOKEN=

# ─── PubMed API ───────────────────────────────────────────────────────────────
# Free key at: https://www.ncbi.nlm.nih.gov/account/
# Increases rate limit from 3/s to 10/s. Leave blank to run without a key.
PUBMED_API_KEY=

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_DAYS=mon,wed,fri
SCHEDULE_TIME=08:00

# ─── App ──────────────────────────────────────────────────────────────────────
# Password to log into the review dashboard
# Pick something only you know — it protects your public URL
DASHBOARD_PASSWORD=choose-a-strong-password-here

# Generate a random secret: open PythonAnywhere console and run:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-string

DATABASE_URL=sqlite:///health_agent.db
OUTPUT_DIR=./output/images
